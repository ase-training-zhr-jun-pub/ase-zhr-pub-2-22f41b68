{
    "apiKeyHelper": "echo $ANTHROPIC_API_KEY",
    "model": "claude-sonnet-4-6",
    "statusLine": {
        "type": "command",
        "command": "$CLAUDE_PROJECT_DIR/.claude/statusline.sh"
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/java-format.sh"
          }
        ]
      }
    ]
  },
    "enableAllProjectMcpServers": true,
    "enabledMcpjsonServers": [
        "context7",
        "playwright"
    ]
}